# Color scheme (catppuccin frappe)
theme = Catppuccin Frappe

# Window settings
window-padding-x = 2
window-padding-y = 2

# Font settings
font-family = UDEV Gothic 35 Regular
font-size = 13

background-opacity = 1
background-opacity-cells = true

# Link settings
link-url = true

# Top-level Ghostty shells may enter Herdr from .zshrc.
env = HERDR_AUTO_ENTRY=1
