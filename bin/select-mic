#!/usr/bin/env bash

set -euo pipefail

require_command() {
  local command_name="$1"
  local install_hint="$2"

  if command -v "$command_name" >/dev/null 2>&1; then
    return 0
  fi

  printf '%s not found. Install with: %s\n' "$command_name" "$install_hint" >&2
  exit 127
}

strip_marker() {
  local selection="$1"

  case "$selection" in
    "* "*)
      printf '%s\n' "${selection#\* }"
      ;;
    "  "*)
      printf '%s\n' "${selection#  }"
      ;;
    *)
      printf '%s\n' "$selection"
      ;;
  esac
}

build_menu() {
  local current="$1"
  local device

  while IFS= read -r device; do
    if [[ -z "$device" ]]; then
      continue
    fi

    if [[ "$device" == "$current" ]]; then
      printf '* %s\n' "$device"
      continue
    fi

    printf '  %s\n' "$device"
  done
}

require_command "SwitchAudioSource" "brew install switchaudio-osx"
require_command "peco" "brew install peco"
require_command "jq" "brew install jq"

devices="$(SwitchAudioSource -a -t input -f json | jq -r '.name // empty')"
if [[ -z "$devices" ]]; then
  printf 'input audio device not found\n' >&2
  exit 1
fi

current="$(SwitchAudioSource -c -t input -f json | jq -r '.name // empty')"
selection="$(build_menu "$current" <<<"$devices" | peco)" || exit 130
if [[ -z "$selection" ]]; then
  exit 130
fi

selected_device="$(strip_marker "$selection")"
if [[ -z "$selected_device" ]]; then
  exit 130
fi

SwitchAudioSource -s "$selected_device" -t input >/dev/null
SwitchAudioSource -c -t input -f json | jq -r '.name // empty'
