#!/bin/bash
# Wrapper for Claude Code Agent Teams teammates on Bedrock.
# Rewrites --model to the correct global inference profile ID.

BEDROCK_MODEL="global.anthropic.claude-opus-4-6-v1"

args=()
while [[ $# -gt 0 ]]; do
  if [[ "$1" == "--model" ]]; then
    args+=("--model" "$BEDROCK_MODEL")
    shift 2
  else
    args+=("$1")
    shift
  fi
done

exec /opt/homebrew/bin/claude "${args[@]}"
